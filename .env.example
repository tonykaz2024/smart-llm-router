# Smart LLM Router — Environment Variables
# Copy this to .env and fill in your values

# Vertex AI Service Account key file path
VERTEX_SA_KEY=path/to/your-vertex-sa-key.json
VERTEX_PROJECT=your-gcp-project-id

# Z.AI API key (for GLM models via api.z.ai)
ZAI_API_KEY=your-zai-api-key

# Optional: Brave Search API key (2000 req/mo free)
BRAVE_API_KEY=

# Optional: YouTube Data API v3 key (100 req/day free)
YOUTUBE_API_KEY=
